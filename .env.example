# Growth Atlas uses Netlify DB (Neon Postgres) + Netlify Functions.
#
# In production you set these in the Netlify UI (Site configuration >
# Environment variables), NOT in this file:
#
#   NETLIFY_DATABASE_URL  REQUIRED. The Neon Postgres connection string the
#                         API function uses. Provisioning Netlify DB usually
#                         sets it automatically, but if data loads fail with
#                         "Database not configured. Set NETLIFY_DATABASE_URL.",
#                         add it manually: Site configuration > Environment
#                         variables > add NETLIFY_DATABASE_URL, scoped to
#                         Builds + Functions + Runtime, then redeploy. Get the
#                         value from the Neon dashboard (Netlify DB > open in
#                         Neon > connection string). Never commit this value.
#
#   APP_PASSWORD     The shared team password everyone logs in with.
#   ADMIN_PASSWORD   (optional) A separate password that unlocks admin
#                    actions like deleting clients. If you skip it, everyone
#                    who has APP_PASSWORD can delete too.
#   SESSION_SECRET   (optional, recommended) A long random string (e.g.
#                    `openssl rand -hex 32`) that signs login session tokens.
#                    Without it the signing key is derived from the two
#                    passwords above — works with zero extra config, but then
#                    rotating a password signs everyone out, and per-user
#                    (email) login needs this once the shared passwords are
#                    removed.
#
#   ---- Google (Gmail + Calendar) integration — OPTIONAL ----
#   The app works fully without these; setting them enables the Settings >
#   Google connection (import client emails, push follow-ups to Calendar).
#
#   GOOGLE_CLIENT_ID      OAuth 2.0 "Web application" client ID from Google
#                         Cloud Console (APIs & Services > Credentials).
#   GOOGLE_CLIENT_SECRET  The matching client secret.
#   GOOGLE_REDIRECT_URI   (optional) Override the OAuth redirect. Defaults to
#                         "<your-site-origin>/api/google". Whatever value is
#                         used MUST be added as an Authorized redirect URI on
#                         the OAuth client in Google Cloud.
#   Also enable the Gmail API and Google Calendar API for the project, and add
#   the scopes gmail.readonly + calendar.events + userinfo.email on the consent
#   screen. See the README "Google integration" section for the full walkthrough.
#
# For local development with `netlify dev`, copy this file to ".env" and fill in
# real values. Do NOT commit your ".env" (it is gitignored).
NETLIFY_DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require
APP_PASSWORD=change-me
ADMIN_PASSWORD=change-me-too
#SESSION_SECRET=paste-output-of-openssl-rand-hex-32

# ---------------------------------------------------------------------------
# Optional integrations. Each one is a graceful no-op when unset — the feature
# just stays hidden or skipped. Uncomment only what you want to test locally.
# Full descriptions: README > "Optional integrations & environment variables".
# ---------------------------------------------------------------------------

# White-label name shown on client portal pages (default "Growth Atlas").
#AGENCY_NAME=Your Agency

# DataForSEO credentials — enables daily automatic keyword rank checks.
#DATAFORSEO_LOGIN=you@example.com
#DATAFORSEO_PASSWORD=your-dataforseo-password

# Resend API key — enables ALL outgoing email (monthly client report emails
# and the daily internal overdue digest).
#RESEND_API_KEY=re_xxxxxxxxxxxx
# From address for those emails (must be on a domain verified in Resend;
# the default onboarding@resend.dev only delivers to your own account).
#REPORT_FROM_EMAIL=Growth Atlas <reports@youragency.com>
# Recipient(s) of the daily overdue digest, comma-separated for several.
#DIGEST_EMAIL=team@youragency.com

# Stripe — enables "Payment link" buttons on the Revenue tab.
#STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
# Webhook endpoint signing secret (endpoint URL: /api/stripe-webhook,
# event: checkout.session.completed) — auto-marks payments Paid.
#STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
# Payment link currency (default usd).
#STRIPE_CURRENCY=usd

# Google Search Console — enables the nightly organic-performance sync.
# Paste the service account's ENTIRE JSON key file contents on one line.
#GSC_SERVICE_ACCOUNT_JSON={"type":"service_account", ... }

# Google OAuth (Gmail + Calendar sync) — enables Settings > Connect Google.
#GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=xxxxxxxx
#GOOGLE_REDIRECT_URI=https://your-site.netlify.app/api/google
